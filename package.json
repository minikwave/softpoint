{
  "name": "softpoint",
  "version": "0.2.0",
  "private": true,
  "description": "SoftPoint — programmable credit engine, consumer d-app, operator console",
  "scripts": {
    "build": "pnpm -r run build",
    "build:domain": "pnpm --filter @softpoint/domain run build",
    "build:sdk": "pnpm --filter @softpoint/sdk run build",
    "build:api": "pnpm --filter softpoint-api run build",
    "build:web": "pnpm --filter softpoint-web run build",
    "build:console": "pnpm --filter operator-console run build",
    "dev": "pnpm --filter softpoint-api run dev",
    "dev:api": "pnpm --filter softpoint-api run dev",
    "dev:web": "pnpm --filter softpoint-web run dev",
    "dev:console": "pnpm --filter operator-console run dev",
    "serve": "concurrently -n api,web -c blue,green \"pnpm --filter softpoint-api run dev\" \"pnpm --filter softpoint-web run dev\"",
    "db:generate": "pnpm --filter softpoint-api run db:generate",
    "db:migrate": "pnpm --filter softpoint-api run db:migrate",
    "db:push": "pnpm --filter softpoint-api run db:push",
    "db:seed": "pnpm --filter softpoint-api run db:seed",
    "test": "pnpm --filter @softpoint/domain run test",
    "smoke": "node scripts/smoke-api.mjs",
    "smoke:prod": "node scripts/smoke-api.mjs https://softpoint-production.up.railway.app"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "packageManager": "pnpm@9.0.0"
}
