# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/paypoint"

# API
API_PORT=3000
API_HOST=0.0.0.0

# Security — unset = open (local dev). Set in production.
USER_JWT_SECRET=
ADMIN_API_KEY=

# SoftPay → SoftPoint loyalty earn (HMAC must match SoftPay WEBHOOK_SECRET)
# SOFTPAY_WEBHOOK_SECRET=
# SOFTPAY_EARN_ENABLED=1
# SOFTPAY_DEFAULT_USER_ID=U1

# Observability
ENABLE_PROMETHEUS_METRICS=false

# Operator Console (Vite proxy → API, optional if ADMIN_API_KEY set on API)
# VITE_ADMIN_API_KEY=
