# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/paypoint"

# API
API_PORT=3000
API_HOST=0.0.0.0

# Security (generate with: openssl rand -hex 32)
JWT_SECRET=
API_KEY=

# When set, every /v1/admin/* request must send this value as:
#   header x-admin-api-key: <value>   OR   Authorization: Bearer <value>
# Leave empty for local dev (no admin auth).
ADMIN_API_KEY=

# When set, all /v1/paypoint/* require Authorization: Bearer <JWT> (HS256).
# JWT payload: sub = user_id (must match path/query/body user_id).
# Leave empty for open demo API.
USER_JWT_SECRET=

# Optional: Idempotency key store (default: in-memory for MVP)
# REDIS_URL=redis://localhost:6379
